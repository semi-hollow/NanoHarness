{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Agent Forge: Doctor",
      "type": "shell",
      "command": "source .venv/bin/activate && forge doctor",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Agent Forge: Run mock smoke",
      "type": "shell",
      "command": "source .venv/bin/activate && forge run \"修复 examples/demo_repo 里的测试失败问题\" --provider mock",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Agent Forge: SWE-bench sample",
      "type": "shell",
      "command": "source .venv/bin/activate && forge bench swebench --limit 1 --provider deepseek --direct-baseline",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Agent Forge: Verify smoke",
      "type": "shell",
      "command": "source .venv/bin/activate && scripts/verify.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    }
  ]
}

#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${PROJECT_DIR}"

if [ ! -f ".venv/bin/activate" ]; then
  echo "Missing .venv. Run scripts/setup_macos_local.sh first." >&2
  exit 1
fi

# shellcheck disable=SC1091
source .venv/bin/activate

export AGENT_FORGE_BASE_URL="https://your-api-host/v1"
export AGENT_FORGE_API_KEY="your-api-key"
export AGENT_FORGE_MODEL="your-model"

python run_demo.py --mode single --llm openai --trace-file trace-online.json
python -m json.tool trace-online.json > trace-online.pretty.json

echo "Wrote ${PROJECT_DIR}/trace-online.json"
echo "Wrote ${PROJECT_DIR}/trace-online.pretty.json"

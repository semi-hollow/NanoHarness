{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Agent Forge: Run single demo",
      "type": "shell",
      "command": "source .venv/bin/activate && python run_demo.py --mode single --trace-file trace-task.json",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Agent Forge: Run tests",
      "type": "shell",
      "command": "source .venv/bin/activate && python -m unittest discover tests",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Agent Forge: Run verify",
      "type": "shell",
      "command": "source .venv/bin/activate && scripts/verify.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Agent Forge: Pretty trace",
      "type": "shell",
      "command": "source .venv/bin/activate && python -m json.tool trace-task.json > trace-task.pretty.json",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    }
  ]
}
